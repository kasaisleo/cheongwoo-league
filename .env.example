# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 운영진 인증 (회원 로그인 없음, 운영진만 비밀번호로 보호)
ADMIN_PASSWORD=change-me
MANAGER_PASSWORD=change-me-too
ADMIN_SESSION_SECRET=change-me-to-a-long-random-string

# 일반 회원 카카오 로그인 (Step 10) — Supabase Auth를 통해 처리되므로
# 이 앱의 환경변수에는 별도 카카오 Client ID/Secret이 필요 없다.
# Supabase 대시보드(Authentication > Providers > Kakao)에서 카카오 개발자
# 콘솔의 REST API 키/Client Secret을 등록하고, Redirect URI를 아래로 설정:
#   https://<project>.vercel.app/auth/callback (production)
#   http://localhost:3000/auth/callback (local)
